// ==UserScript==
// @name         SaveTwitter Multi-Paste & Queue Downloader (Manual Reset)
// @namespace    http://tampermonkey.net/
// @version      1.9
// @description  Adds a manual reset/finish button on the last item of the queue
// @author       User
// @match        https://savetwitter.net/*
// @match        https://*.savetwitter.net/*
// @grant        none
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    // 1. 입력창을 고정된 10줄 높이의 Textarea로 교체하는 함수
    function replaceInput() {
        const oldInput = document.getElementById('s_input');
        if (oldInput && oldInput.tagName === 'INPUT') {
            const textarea = document.createElement('textarea');
            
            // 기존 속성 복사
            for (const attr of oldInput.attributes) {
                textarea.setAttribute(attr.name, attr.value);
            }
            
            // 클래스 부여
            textarea.className = oldInput.className + ' textarea';
            
            // 가로 누수 차단 및 스타일 지정 [1]
            textarea.style.boxSizing = 'border-box'; // 패딩과 테두리를 너비 계산에 포함 [1]
            textarea.style.width = '100%';
            textarea.style.maxWidth = '100%'; // 가로폭 초과 방지 [1]
            textarea.style.height = '200px';
            textarea.style.resize = 'none'; // 크기 조절 비활성화
            textarea.style.fontFamily = 'inherit';
            
            // 패딩 2배 상향 (24px)
            textarea.style.padding = '24px';
            textarea.style.lineHeight = '1.6';
            textarea.style.overflowY = 'auto'; // 내용이 많아지면 세로 스크롤만 허용
            
            // 테두리 두껍고 명확하게 적용 (2px)
            textarea.style.border = '2px solid #7a7a7a';
            textarea.style.borderRadius = '8px'; // 모서리 둥글기 부드럽게 유지
            
            oldInput.parentNode.replaceChild(textarea, oldInput);
        }
    }

    // 2. 실시간 정규식 감지 및 자동 엔터 메커니즘
    document.addEventListener('input', (e) => {
        const tx = e.target;
        if (tx && tx.id === 's_input' && tx.tagName === 'TEXTAREA') {
            const val = tx.value;
            // 트위터/X 주소 형식 감지용 정규표현식
            const twitterRegex = /https?:\/\/(twitter|x)\.com\/[a-zA-Z0-9_]+\/status\/\d+[^ \n]*$/;
            
            if (twitterRegex.test(val)) {
                // 링크가 온전하게 인식되면 즉시 끝에 줄바꿈 추가
                tx.value = val + '\n';
                tx.scrollTop = tx.scrollHeight; // 다음 작성을 위해 스크롤을 맨 아래로 내림
                
                // 프레임워크 연동을 위한 이벤트 강제 전파
                tx.dispatchEvent(new Event('input', { bubbles: true }));
                tx.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }
    }, true);

    // 3. 다운로드 버튼 클릭 시 다중 링크인 경우 대기열에 저장 (이벤트 위임)
    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.btn-red');
        if (btn) {
            const textarea = document.getElementById('s_input');
            if (textarea && textarea.tagName === 'TEXTAREA') {
                const lines = textarea.value.split('\n').map(l => l.trim()).filter(l => l.length > 0);
                
                // 사용자의 직접적인 마우스 클릭(isTrusted: true)일 때만 작동하여 자동화 루프 간섭 배제
                if (e.isTrusted) {
                    if (lines.length > 1) {
                        const firstUrl = lines[0];
                        const queue = lines.slice(1);
                        
                        // 대기열 및 전체 수량(N) 기록 저장
                        sessionStorage.setItem('savetwitter_queue', JSON.stringify(queue));
                        sessionStorage.setItem('savetwitter_total', lines.length.toString());
                        
                        textarea.value = firstUrl;
                        textarea.dispatchEvent(new Event('input', { bubbles: true }));
                        textarea.dispatchEvent(new Event('change', { bubbles: true }));
                    } else {
                        // 사용자가 직접 '다운로드'를 새 단일 링크로 진행하는 경우 기존 세션 클리어
                        sessionStorage.removeItem('savetwitter_queue');
                        sessionStorage.removeItem('savetwitter_total');
                    }
                }
            }
        }
    }, true);

    // 4. 대기열 다음 단계로 넘어가는 화살표 버튼 추가 및 제어
    function checkResultPage() {
        const moreVideoBtn = document.querySelector('.more-video');
        const queueStr = sessionStorage.getItem('savetwitter_queue');
        const totalStr = sessionStorage.getItem('savetwitter_total');
        
        if (moreVideoBtn && queueStr) {
            const queue = JSON.parse(queueStr);
            if (queue && Array.isArray(queue)) {
                if (!document.getElementById('savetwitter-next-btn')) {
                    const nextBtn = document.createElement('a');
                    nextBtn.id = 'savetwitter-next-btn';
                    nextBtn.href = 'javascript:void(0);'; // 링크 기능을 자바스크립트로 대체
                    
                    nextBtn.className = 'button is-dark is-fullwidth';
                    
                    // 레이아웃 스크롤 방지 스타일 [1]
                    nextBtn.style.marginTop = '10px';
                    nextBtn.style.boxSizing = 'border-box'; // 초과 방지 [1]
                    nextBtn.style.maxWidth = '100%'; // 초과 방지 [1]
                    nextBtn.style.cursor = 'pointer';
                    
                    const total = parseInt(totalStr, 10) || 1;
                    
                    // Case A: 대기열이 아직 남아있을 경우 (다음 분석 버튼 표시)
                    if (queue.length > 0) {
                        const current = total - queue.length;
                        
                        nextBtn.innerHTML = `
                            <span>다음 동영상 분석 ( ${current} / ${total} )</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-left: 8px;">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                        `;
                        
                        nextBtn.addEventListener('click', (e) => {
                            e.preventDefault();
                            sessionStorage.setItem('savetwitter_auto_run', 'true');
                            
                            const originalBtn = document.querySelector('.more-video');
                            if (originalBtn) {
                                originalBtn.click();
                            } else {
                                window.location.href = '/';
                            }
                        });
                    } 
                    // Case B: 마지막 동영상 단계일 경우 (종료 및 수동 초기화 버튼 표시) [1]
                    else {
                        nextBtn.innerHTML = `
                            <span>다운로드 종료 및 초기화 ( ${total} / ${total} )</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-left: 8px;">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        `;
                        
                        nextBtn.addEventListener('click', (e) => {
                            e.preventDefault();
                            // 수동 버튼 클릭 시 세션 내부를 완전하게 초기화하고 메인으로 이동 [1]
                            sessionStorage.removeItem('savetwitter_queue');
                            sessionStorage.removeItem('savetwitter_total');
                            sessionStorage.removeItem('savetwitter_auto_run');
                            
                            const originalBtn = document.querySelector('.more-video');
                            if (originalBtn) {
                                originalBtn.click();
                            } else {
                                window.location.href = '/';
                            }
                        });
                    }
                    
                    moreVideoBtn.parentNode.insertBefore(nextBtn, moreVideoBtn.nextSibling);
                }
            }
        }
    }

    // 5. 대기열 자동 실행
    function runAutoQueue() {
        const autoRun = sessionStorage.getItem('savetwitter_auto_run');
        const queueStr = sessionStorage.getItem('savetwitter_queue');
        
        if (autoRun === 'true' && queueStr) {
            const queue = JSON.parse(queueStr);
            if (queue && Array.isArray(queue)) {
                const checkExist = setInterval(() => {
                    const input = document.getElementById('s_input');
                    const btn = document.querySelector('.btn-red');
                    
                    if (input && btn) {
                        clearInterval(checkExist);
                        
                        const nextUrl = queue.shift();
                        
                        // [수정] 마지막 항목을 실행하더라도 큐가 완전히 끝난 것은 아니므로(결과 화면을 보아야 하므로)
                        // 임시로 빈 배열 '[]' 상태를 세션에 유지시켜 줍니다.
                        sessionStorage.setItem('savetwitter_queue', JSON.stringify(queue));
                        sessionStorage.removeItem('savetwitter_auto_run');
                        
                        if (input.tagName === 'INPUT') {
                            replaceInput();
                        }
                        
                        const textarea = document.getElementById('s_input');
                        if (textarea) {
                            textarea.value = nextUrl;
                            textarea.dispatchEvent(new Event('input', { bubbles: true }));
                            textarea.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                        
                        setTimeout(() => {
                            btn.click(); // 가상 클릭은 세션 제거를 유발하지 않습니다.
                        }, 500);
                    }
                }, 100);
            }
        }
    }

    // 초기 및 지속 실행 감지 루프
    runAutoQueue();
    
    setInterval(() => {
        const currentInput = document.getElementById('s_input');
        if (currentInput && currentInput.tagName === 'INPUT') {
            replaceInput();
        }
        checkResultPage();
    }, 300);

})();
