// ==UserScript==
// @name         SaveTwitter Multi-Paste & Queue Downloader (Style Matched)
// @namespace    http://tampermonkey.net/
// @version      1.3
// @description  Robust multi-line pasting, auto newline, and queue downloader with matched button style
// @author       User
// @match        https://savetwitter.net/*
// @match        https://*.savetwitter.net/*
// @grant        none
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    // 1. 입력창을 고정된 10줄 높이의 Textarea로 교체하는 함수
    function replaceInput() {
        const oldInput = document.getElementById('s_input');
        if (oldInput && oldInput.tagName === 'INPUT') {
            const textarea = document.createElement('textarea');
            
            // 기존 속성 복사
            for (const attr of oldInput.attributes) {
                textarea.setAttribute(attr.name, attr.value);
            }
            
            // 10줄 정도의 높이(약 200px)로 고정하고 세로 스크롤 허용
            textarea.className = oldInput.className + ' textarea';
            textarea.style.height = '200px';
            textarea.style.resize = 'none'; // 크기 조절 비활성화 (고정)
            textarea.style.fontFamily = 'inherit';
            textarea.style.padding = '12px';
            textarea.style.lineHeight = '1.5';
            textarea.style.width = '100%';
            textarea.style.overflowY = 'auto'; // 내용이 많아지면 스크롤바 표시
            
            oldInput.parentNode.replaceChild(textarea, oldInput);
        }
    }

    // 2. 실시간 정규식 감지 및 자동 엔터 메커니즘
    document.addEventListener('input', (e) => {
        const tx = e.target;
        if (tx && tx.id === 's_input' && tx.tagName === 'TEXTAREA') {
            const val = tx.value;
            // 트위터/X 주소 형식 감지용 정규표현식
            const twitterRegex = /https?:\/\/(twitter|x)\.com\/[a-zA-Z0-9_]+\/status\/\d+[^ \n]*$/;
            
            if (twitterRegex.test(val)) {
                // 링크가 온전하게 인식되면 즉시 끝에 줄바꿈 추가
                tx.value = val + '\n';
                tx.scrollTop = tx.scrollHeight; // 다음 작성을 위해 스크롤을 맨 아래로 내림
                
                // 프레임워크 연동을 위한 이벤트 강제 전파
                tx.dispatchEvent(new Event('input', { bubbles: true }));
                tx.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }
    }, true);

    // 3. 다운로드 버튼 클릭 시 다중 링크인 경우 대기열에 저장 (이벤트 위임)
    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.btn-red');
        if (btn) {
            const textarea = document.getElementById('s_input');
            if (textarea && textarea.tagName === 'TEXTAREA') {
                const lines = textarea.value.split('\n').map(l => l.trim()).filter(l => l.length > 0);
                
                // 줄바꿈으로 구분된 링크가 2개 이상일 때만 동작
                if (lines.length > 1) {
                    const firstUrl = lines[0];
                    const queue = lines.slice(1);
                    
                    sessionStorage.setItem('savetwitter_queue', JSON.stringify(queue));
                    
                    textarea.value = firstUrl;
                    textarea.dispatchEvent(new Event('input', { bubbles: true }));
                    textarea.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
        }
    }, true);

    // 4. 대기열 다음 단계로 넘어가는 화살표 버튼 추가 및 제어
    function checkResultPage() {
        const moreVideoBtn = document.querySelector('.more-video');
        const queueStr = sessionStorage.getItem('savetwitter_queue');
        
        if (moreVideoBtn && queueStr) {
            const queue = JSON.parse(queueStr);
            if (queue && queue.length > 0) {
                if (!document.getElementById('savetwitter-next-btn')) {
                    const nextBtn = document.createElement('button');
                    nextBtn.id = 'savetwitter-next-btn';
                    
                    // 기본 Bulma 버튼 클래스 부여 (is-fullwidth 추가로 기존 위치 형태에 맞춤)
                    nextBtn.className = 'button is-fullwidth';
                    
                    // 요청하신 CSS 양식을 자바스크립트 인라인 스타일에 반영
                    nextBtn.style.marginTop = '10px';
                    nextBtn.style.backgroundColor = '#fff';
                    nextBtn.style.borderColor = '#dbdbdb';
                    nextBtn.style.borderWidth = '1px';
                    nextBtn.style.borderStyle = 'solid';
                    nextBtn.style.color = '#363636';
                    nextBtn.style.cursor = 'pointer';
                    nextBtn.style.justifyContent = 'center';
                    nextBtn.style.paddingBottom = 'calc(.5em - 1px)';
                    nextBtn.style.paddingLeft = '1em';
                    nextBtn.style.paddingRight = '1em';
                    nextBtn.style.paddingTop = 'calc(.5em - 1px)';
                    nextBtn.style.textAlign = 'center';
                    nextBtn.style.whiteSpace = 'nowrap';
                    nextBtn.style.display = 'inline-flex';
                    nextBtn.style.alignItems = 'center';
                    nextBtn.style.gap = '8px';
                    nextBtn.style.fontWeight = 'bold';
                    
                    // 텍스트 및 SVG 주입 (부모 글자색인 #363636을 물려받도록 currentColor 설정)
                    nextBtn.innerHTML = `
                        <span>다음 동영상 분석 (남은 큐: ${queue.length}개)</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle;">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    `;
                    
                    nextBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        sessionStorage.setItem('savetwitter_auto_run', 'true');
                        
                        const originalBtn = document.querySelector('.more-video');
                        if (originalBtn) {
                            originalBtn.click();
                        } else {
                            window.location.href = '/';
                        }
                    });
                    
                    moreVideoBtn.parentNode.insertBefore(nextBtn, moreVideoBtn.nextSibling);
                }
            }
        }
    }

    // 5. 대기열 자동 실행
    function runAutoQueue() {
        const autoRun = sessionStorage.getItem('savetwitter_auto_run');
        const queueStr = sessionStorage.getItem('savetwitter_queue');
        
        if (autoRun === 'true' && queueStr) {
            const queue = JSON.parse(queueStr);
            if (queue && queue.length > 0) {
                const checkExist = setInterval(() => {
                    const input = document.getElementById('s_input');
                    const btn = document.querySelector('.btn-red');
                    
                    if (input && btn) {
                        clearInterval(checkExist);
                        
                        const nextUrl = queue.shift();
                        sessionStorage.setItem('savetwitter_queue', JSON.stringify(queue));
                        sessionStorage.removeItem('savetwitter_auto_run');
                        
                        if (input.tagName === 'INPUT') {
                            replaceInput();
                        }
                        
                        const textarea = document.getElementById('s_input');
                        if (textarea) {
                            textarea.value = nextUrl;
                            textarea.dispatchEvent(new Event('input', { bubbles: true }));
                            textarea.dispatchEvent(new Event('change', { bubbles: true }));
                        }
                        
                        setTimeout(() => {
                            btn.click();
                        }, 500);
                    }
                }, 100);
            } else {
                sessionStorage.removeItem('savetwitter_auto_run');
            }
        }
    }

    // 초기 및 지속 실행 감지 루프
    runAutoQueue();
    
    setInterval(() => {
        const currentInput = document.getElementById('s_input');
        if (currentInput && currentInput.tagName === 'INPUT') {
            replaceInput();
        }
        checkResultPage();
    }, 300);

})();
